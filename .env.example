# ─────────────────────────────────────────────────────────────────────────────
# SpringCloud Library System — Environment Variables
# Copy this file to .env and fill in values before running locally.
# In production (AWS ECS) these are injected via the ECS task definition
# and AWS SSM Parameter Store — never commit real values to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Shared: JWT ──────────────────────────────────────────────────────────────
# Must be the same across user-service AND book-service (both validate tokens).
# Production value lives in AWS SSM: /library-prod/jwt-secret
# Generate a new one with: openssl rand -hex 32
JWT_SECRET=replace-me-with-a-256-bit-hex-secret

# ── Shared: Eureka ───────────────────────────────────────────────────────────
# URL all services use to register and discover each other.
# Local default: http://localhost:8761/eureka
# In ECS, this points to the Eureka container via its Eureka service name.
EUREKA_URL=http://localhost:8761/eureka

# ── Shared: AWS / SQS ────────────────────────────────────────────────────────
AWS_REGION=us-east-1

# SQS queue URL — user-service publishes, book-service consumes.
# Local: use LocalStack (see docker-compose.yml)
# Production: set by Terraform output (aws_sqs_queue.user_name_changes.url)
USER_NAME_CHANGES_QUEUE_URL=http://localhost:4566/000000000000/user-name-changes

# Leave blank in production (real AWS SDK endpoint is used automatically).
# Set to http://localhost:4566 when running LocalStack locally.
AWS_SQS_ENDPOINT_OVERRIDE=http://localhost:4566

# ── eureka-server ────────────────────────────────────────────────────────────
# Default port: 8761
EUREKA_SERVER_PORT=8761

# ── api-gateway ──────────────────────────────────────────────────────────────
# Default port: 8080
API_GATEWAY_PORT=8080

# ── user-service ─────────────────────────────────────────────────────────────
# Default port: 8085
USER_SERVICE_PORT=8085

# ── book-service ─────────────────────────────────────────────────────────────
# Default port: 8086
BOOK_SERVICE_PORT=8086

# URL used by book-service to call user-service directly (for status checks).
# Local: http://localhost:8085
# In ECS: http://user-service (Eureka resolves the service name)
USER_SERVICE_URL=http://localhost:8085

# ── GitHub Actions (CI/CD) ───────────────────────────────────────────────────
# These live as GitHub repository secrets — never in this file.
# AWS_ROLE_ARN  = arn:aws:iam::<account-id>:role/library-prod-github-actions
# (Created by Terraform in infra/iam.tf — check Terraform outputs)

# ── Terraform / Infra ────────────────────────────────────────────────────────
# Set in infra/terraform.tfvars (not committed — see terraform.tfvars.example)
# TF_VAR_jwt_secret=<same value as JWT_SECRET above>
